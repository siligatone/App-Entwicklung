# Firebase Konfiguration
# Kopiere diese Datei zu .env und trage deine Werte ein.
# Die Werte findest du in der Firebase Console unter:
# Projekteinstellungen > Deine Apps > Web-App > SDK-Setup und Konfiguration

EXPO_PUBLIC_FIREBASE_API_KEY=HIER_EINTRAGEN
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=HIER_EINTRAGEN
EXPO_PUBLIC_FIREBASE_PROJECT_ID=HIER_EINTRAGEN
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=HIER_EINTRAGEN
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=HIER_EINTRAGEN
EXPO_PUBLIC_FIREBASE_APP_ID=HIER_EINTRAGEN

# Gemini KI (optional — für KI-Unteraufgaben-Vorschläge)
# Key erstellen: https://aistudio.google.com/apikey
# DEMO-HINWEIS: EXPO_PUBLIC_ ist clientseitig sichtbar und NICHT produktionssicher.
# Für eine echte App müsste der Key in einem Backend liegen (Firebase Function, n8n, etc.).
EXPO_PUBLIC_GEMINI_API_KEY=HIER_EINTRAGEN
